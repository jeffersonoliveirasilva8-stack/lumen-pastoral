# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sentry (monitoramento de erros) ───────────────────────────────────────────
# DSN público do projeto no Sentry — seguro para expor no frontend
VITE_SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/0
# Token de autenticação para upload de source maps (CI/CD apenas)
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=sua-org
SENTRY_PROJECT=lumen-pastoral

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# Site key pública (visível no HTML — não é segredo)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAAAAAAAAAAAAAAAAA
# Secret key usada apenas no servidor (Edge Function / backend)
TURNSTILE_SECRET_KEY=0x4AAAAAAAAAAAAAAAAAAAAAAA

# ── E-mail transacional (Edge Function send-email) ────────────────────────────
# Configurar no Supabase Dashboard → Edge Functions → Secrets
# (NÃO adicionar aqui no .env local — são segredos de servidor)
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   Chave da API do Resend (resend.com). Plano gratuito: 3.000 e-mails/mês.
#   Criar em: https://resend.com/api-keys
#
# SITE_URL=https://seuprojeto.com.br
#   URL base da aplicação em produção (sem barra final).
#   Usada para montar links nos e-mails (ex: /membro/ativar-conta).
#
# EMAIL_FROM=Lumen Pastoral <noreply@suaparoquia.com.br>
#   Remetente dos e-mails. O domínio deve estar verificado no Resend.
#   Domínio não verificado: use o domínio padrão do Resend (onboarding@resend.dev).
#
# Como configurar os segredos no Supabase:
#   supabase secrets set RESEND_API_KEY=re_xxx SITE_URL=https://... EMAIL_FROM="..."
# Ou via Dashboard: https://supabase.com/dashboard/project/_/settings/functions
